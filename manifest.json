{
  "manifest_version": 3,
  "name": "Badminton Tracker",
  "version": "1.3",
  "description": "First scrape toernooi.nl, and then BadmintonVlaanderen for better results",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.badmintonvlaanderen.be/*",
    "https://www.toernooi.nl/*",
    "https://lfbb.tournamentsoftware.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.badmintonvlaanderen.be/profile/matches.aspx*",
        "https://www.toernooi.nl/player-profile/*/Rating",
        "https://lfbb.tournamentsoftware.com/player-profile/*/Rating"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [{
    "resources": ["content.js", "utils.js", "scraper-utils.js"],
    "matches": ["https://www.badmintonvlaanderen.be/*", "https://www.toernooi.nl/*", "https://lfbb.tournamentsoftware.com/*"]
  }]
}